{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["miniprogram-api-typings", "node"]
  },
  "include": ["miniprogram/**/*.ts", "tests/**/*.ts", "vitest.config.ts"],
  "exclude": ["node_modules"]
}
