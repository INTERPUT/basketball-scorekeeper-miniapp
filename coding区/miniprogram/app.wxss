page {
  background: #f5f7fb;
  color: #16202a;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.panel {
  background: #ffffff;
  border: 1rpx solid #d8dee8;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.field {
  margin-bottom: 24rpx;
}

.label {
  display: block;
  margin-bottom: 10rpx;
  color: #475467;
}

.input,
.textarea {
  width: 100%;
  min-height: 72rpx;
  border: 1rpx solid #d8dee8;
  background: #ffffff;
  padding: 18rpx 20rpx;
  box-sizing: border-box;
}

.textarea {
  min-height: 180rpx;
}

.button-row {
  display: flex;
  gap: 16rpx;
}

.button-row button {
  flex: 1;
}

.primary {
  background: #0f766e;
  color: #ffffff;
}

.secondary {
  background: #ffffff;
  color: #16202a;
  border: 1rpx solid #d8dee8;
}

.error {
  color: #b42318;
  margin-top: 12rpx;
}

.muted {
  color: #667085;
}

.section-title {
  margin: 0 0 18rpx;
  font-size: 34rpx;
  font-weight: 600;
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.stat {
  border: 1rpx solid #d8dee8;
  padding: 18rpx;
}

.score {
  font-size: 56rpx;
  font-weight: 700;
}

.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border: 1rpx solid #bfdbfe;
  background: #eff6ff;
  color: #1d4ed8;
  font-size: 24rpx;
}
