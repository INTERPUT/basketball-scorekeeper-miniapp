<view class="page">
  <view class="panel">
    <view class="section-title">加入比赛</view>
    <view class="field">
      <text class="label">四位房间码</text>
      <input
        class="input"
        type="number"
        maxlength="4"
        value="{{roomCode}}"
        placeholder="请输入 4 位数字"
        bindinput="onRoomCodeInput"
      />
      <view wx:if="{{error}}" class="error">{{error}}</view>
    </view>
    <view class="button-row">
      <button class="primary" bindtap="handleJoin">进入比赛</button>
      <button class="secondary" bindtap="handleCreate">创建比赛</button>
    </view>
  </view>
  <view class="muted">比赛结束后房间会自动失效。</view>
</view>
