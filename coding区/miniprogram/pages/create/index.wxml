<view class="page">
  <view class="panel">
    <view class="section-title">基础信息</view>
    <view class="field">
      <text class="label">四位房间码</text>
      <input class="input" type="number" maxlength="4" value="{{roomCode}}" bindinput="onRoomCodeInput" />
    </view>
    <view class="field">
      <text class="label">单节时长（分钟）</text>
      <input class="input" type="number" value="{{periodLengthMinutes}}" data-field="periodLengthMinutes" bindinput="onFieldInput" />
    </view>
  </view>

  <view class="panel">
    <view class="section-title">主队</view>
    <view class="field">
      <text class="label">球队名称</text>
      <input class="input" value="{{homeTeamName}}" data-field="homeTeamName" bindinput="onFieldInput" />
    </view>
    <view class="field">
      <text class="label">球衣颜色</text>
      <input class="input" value="{{homeTeamColor}}" data-field="homeTeamColor" bindinput="onFieldInput" />
    </view>
    <view class="field">
      <view class="roster-header">
        <text class="label">球员名单</text>
        <button class="secondary small-button" data-team="home" bindtap="openPlayerModal">添加球员</button>
      </view>
      <view wx:if="{{homePlayers.length}}" class="roster-list">
        <view wx:for="{{homePlayers}}" wx:key="number" class="roster-row">
          <text class="player-number">#{{item.number}}</text>
          <text class="player-name">{{item.name}}</text>
          <button class="remove-button" data-team="home" data-index="{{index}}" bindtap="removePlayer">删除</button>
        </view>
      </view>
      <view wx:else class="empty-roster">暂无球员</view>
    </view>
  </view>

  <view class="panel">
    <view class="section-title">客队</view>
    <view class="field">
      <text class="label">球队名称</text>
      <input class="input" value="{{awayTeamName}}" data-field="awayTeamName" bindinput="onFieldInput" />
    </view>
    <view class="field">
      <text class="label">球衣颜色</text>
      <input class="input" value="{{awayTeamColor}}" data-field="awayTeamColor" bindinput="onFieldInput" />
    </view>
    <view class="field">
      <view class="roster-header">
        <text class="label">球员名单</text>
        <button class="secondary small-button" data-team="away" bindtap="openPlayerModal">添加球员</button>
      </view>
      <view wx:if="{{awayPlayers.length}}" class="roster-list">
        <view wx:for="{{awayPlayers}}" wx:key="number" class="roster-row">
          <text class="player-number">#{{item.number}}</text>
          <text class="player-name">{{item.name}}</text>
          <button class="remove-button" data-team="away" data-index="{{index}}" bindtap="removePlayer">删除</button>
        </view>
      </view>
      <view wx:else class="empty-roster">暂无球员</view>
    </view>
  </view>

  <view class="panel">
    <view class="section-title" bindtap="toggleAdvanced">高级信息 {{showAdvanced ? "收起" : "展开"}}</view>
    <view wx:if="{{showAdvanced}}">
      <view class="field">
        <text class="label">赛事名称</text>
        <input class="input" value="{{competitionName}}" data-field="competitionName" bindinput="onFieldInput" />
      </view>
      <view class="field">
        <text class="label">地点</text>
        <input class="input" value="{{venue}}" data-field="venue" bindinput="onFieldInput" />
      </view>
      <view class="field">
        <text class="label">裁判</text>
        <input class="input" value="{{referee}}" data-field="referee" bindinput="onFieldInput" />
      </view>
    </view>
  </view>

  <view wx:if="{{error}}" class="error">{{error}}</view>
  <button class="primary" bindtap="handleSubmit">创建房间</button>

  <view wx:if="{{playerModalVisible}}" class="modal-backdrop">
    <view class="modal">
      <view class="section-title">添加{{playerModalTeamLabel}}球员</view>
      <view class="field">
        <text class="label">球衣号码</text>
        <input class="input" type="number" maxlength="3" value="{{playerNumber}}" placeholder="例如 7" bindinput="onPlayerNumberInput" />
      </view>
      <view class="field">
        <text class="label">球员名称</text>
        <input class="input" value="{{playerName}}" placeholder="例如 张三" bindinput="onPlayerNameInput" />
      </view>
      <view wx:if="{{playerModalError}}" class="error">{{playerModalError}}</view>
      <view class="button-row modal-actions">
        <button class="secondary" bindtap="closePlayerModal">取消</button>
        <button class="primary" bindtap="confirmPlayerModal">添加</button>
      </view>
    </view>
  </view>
</view>
