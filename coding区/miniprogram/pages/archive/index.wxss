.page {
  min-height: 100vh;
  padding: 24rpx;
  background: #f5f7fb;
  box-sizing: border-box;
}

.panel {
  background: #ffffff;
  border-radius: 8px;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1px solid #e5e7eb;
}

.tag {
  display: inline-block;
  color: #0f766e;
  background: #ccfbf1;
  padding: 4rpx 12rpx;
  border-radius: 4px;
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.muted {
  color: #6b7280;
  font-size: 26rpx;
  word-break: break-all;
}

.error {
  color: #b91c1c;
  background: #fee2e2;
  border: 1px solid #fecaca;
  border-radius: 8px;
  padding: 18rpx;
  margin-bottom: 20rpx;
}

.signature-canvas {
  width: 100%;
  height: 280rpx;
  background: #ffffff;
  border: 1px dashed #9ca3af;
  border-radius: 6px;
  margin: 16rpx 0;
}

.button-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.button-row button {
  flex: 1;
}

.primary {
  background: #0f766e;
  color: #ffffff;
}

.secondary {
  background: #ffffff;
  color: #374151;
  border: 1px solid #d1d5db;
}

.file-row {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1px solid #e5e7eb;
}

.file-action {
  margin-top: 12rpx;
  width: 100%;
}
